{
  "name": "@thodare/api",
  "version": "0.1.1",
  "description": "HTTP control plane for @thodare/engine. Workflows CRUD, LLM patch endpoint, runs + schedules + webhooks, better-auth + organizations.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx examples/full-llm-loop.ts",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "keywords": [
    "thodare",
    "workflow",
    "api",
    "hono",
    "better-auth",
    "ai",
    "agents",
    "control-plane"
  ],
  "license": "MIT",
  "homepage": "https://thodare.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/asyncdotengineering/thodare.git",
    "directory": "packages/api"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.9",
    "@thodare/engine": "workspace:*",
    "better-auth": "^1.6.9",
    "hono": "^4.6.0",
    "@thodare/openworkflow": "workspace:*",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.0",
    "@types/node": "^22.13.5",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
