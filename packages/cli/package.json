{
  "name": "@thodare/cli",
  "version": "0.1.0",
  "description": "Command-line client for @thodare/api.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "thodare": "./src/bin.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "bin": {
      "thodare": "./dist/bin.js"
    },
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "keywords": [
    "thodare",
    "cli",
    "workflow",
    "ai",
    "agents",
    "control-plane"
  ],
  "license": "MIT",
  "homepage": "https://thodare.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/asyncdotengineering/thodare.git",
    "directory": "packages/cli"
  },
  "dependencies": {},
  "devDependencies": {
    "@thodare/api": "workspace:*",
    "@thodare/engine": "workspace:*",
    "@types/node": "^22.13.5",
    "@thodare/openworkflow": "workspace:*",
    "postgres": "^3.4.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9",
    "zod": "^3.23.8"
  }
}
