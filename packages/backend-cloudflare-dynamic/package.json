{
  "name": "@thodare/backend-cloudflare-dynamic",
  "version": "1.0.0-alpha.1",
  "description": "Cloudflare Workflows GA ThodareBackend adapter using @cloudflare/dynamic-workflows — serverless, per-invocation, D1-backed.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "license": "MIT",
  "homepage": "https://thodare.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/asyncdotengineering/thodare.git",
    "directory": "packages/backend-cloudflare-dynamic"
  },
  "dependencies": {
    "@cloudflare/dynamic-workflows": "^0.1.1",
    "@thodare/backend": "workspace:*",
    "@thodare/engine": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@cloudflare/workers-types": "^4.20250502.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.0.0"
  }
}
