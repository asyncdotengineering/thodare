{
  "name": "thodare",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "test:engine": "pnpm --filter @thodare/engine run test",
    "test:api": "pnpm --filter @thodare/api run test",
    "test:cli": "pnpm --filter @thodare/cli run test",
    "build": "pnpm -r run build",
    "docs": "pnpm --filter @thodare/docs run dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8"
  }
}